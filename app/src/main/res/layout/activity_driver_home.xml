<?xml version="1.0" encoding="utf-8"?>
<!--
    Driver Home Activity layout.
    Map is always visible as the background layer.
    All three BottomNav tabs (Dashboard, Requests, Status) load a Fragment
    into fragmentContainer which sits on top of the map.
    Phase 6 — UI Migration Roadmap
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ── Toolbar — ID unchanged ────────────────────────────────────── -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        app:title="@string/driver_home"
        app:titleTextColor="@color/white" />

    <!-- ── Content area ───────────────────────────────────────────────── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Map — always visible as background (ID unchanged) -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Fragment overlay — shown for all three tabs -->
        <FrameLayout
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </FrameLayout>

    <!-- ── BottomNavigationView ───────────────────────────────────────── -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:menu="@menu/menu_driver" />

</LinearLayout>

